<Window x:Class="RobotInterface.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:oscillo="clr-namespace:WpfOscilloscopeControl;assembly=WpfOscilloscopeControl" 
        xmlns:AsservDisplay="clr-namespace:WpfAsservissementDisplay_NS;assembly=WpfAsservissementDisplay"
        xmlns:local="clr-namespace:RobotInterface"
        mc:Ignorable="d"
        Title="MainWindow" Height="762" Width="1055">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="5*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="4*"/>
        </Grid.RowDefinitions>
        <GroupBox x:Name="Emission" Header="GroupBox" Grid.Row="0" Grid.Column="0" Margin="5">
            <TextBox x:Name="TextBoxEmission" TextWrapping="Wrap" Text="" TextChanged="TextBoxEmission_TextChanged" AcceptsReturn="True" KeyUp="TextBoxEmission_KeyUp"/>
        </GroupBox>
        <GroupBox x:Name="Reception" Header="GroupBox" Grid.Row="0" Grid.Column="1" Margin="5">
            <TextBox x:Name="TextBoxReception" TextWrapping="Wrap" Text="" AcceptsReturn="True" IsReadOnly="True"/>
        </GroupBox>
        <oscillo:WpfOscilloscope x:Name="oscilloSpeed" Grid.Row="2" Grid.Column="0" Margin="10,10,205,10"/>
        <AsservDisplay:AsservissementRobot2RouesDisplayControl x:Name="asservSpeedDisplay" Grid.Column="1" Margin="204,0,0,0" Grid.Row="2" Height="288" VerticalAlignment="Bottom"/>



        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="59,13,0,0" Grid.Row="1" Height="38" VerticalAlignment="Top" Width="459">
            <Button x:Name="ButtonEnvoyer" Content="Envoyer" Width="100" Click="ButtonEnvoyer_Click" Margin="5"/>
            <Button x:Name="ButtonClear"  Content="Clear" Width="100" Click="ButtonClear_Click" Margin="5" />
            <Button x:Name="ButtonTest" Content="Test" Width="100" Click="ButtonTest_Click" Margin="5"/>
            <Button x:Name="ButtonMode" Content="Mode" Width="100" Click="ButtonMode_Click" Margin="5"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" Grid.Row="2" Grid.ColumnSpan="2" HorizontalAlignment="Center" Width="400">
            <GroupBox Header="Leds" Width="133">
                <StackPanel Orientation="Vertical">
                    <CheckBox x:Name="Led1" Content="Led1"/>
                    <CheckBox x:Name="Led2" Content="Led2"/>
                    <CheckBox x:Name="Led3" Content="Led3"/>
                </StackPanel>
            </GroupBox>
            <GroupBox Header="Télémètres IR" Width="133">
                <StackPanel Orientation="Vertical">
                    <TextBox x:Name="IRGauche" Text="IR Gauche : 0 cm"/>
                    <TextBox x:Name="IRCentre" Text="IR Centre : 0 cm"/>
                    <TextBox x:Name="IRDroite" Text="IR Droite : 0 cm"/>
                </StackPanel>
            </GroupBox>
            <GroupBox Header="Moteurs" Width="133">
                <StackPanel Orientation="Vertical">
                    <TextBox x:Name="VITGauche" Text="Vitesse Gauche : 0 %"/>
                    <TextBox x:Name="VITDroite" Text="Vitesse Droite : 0 %"/>
                </StackPanel>
            </GroupBox>
        </StackPanel>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="170,0,0,47" Width="209" Grid.Column="1" Grid.RowSpan="2" Height="29" VerticalAlignment="Bottom">
            <TextBox x:Name="TextBoxKp" HorizontalAlignment="Left" TextWrapping="Wrap" Text="Kp:" VerticalAlignment="Top" Width="70" Height="20" Grid.RowSpan="2"/>
            <TextBox x:Name="TextBoxKi" HorizontalAlignment="Left" TextWrapping="Wrap" Text="Ki:" VerticalAlignment="Top" Width="70" Height="20" Grid.RowSpan="2"/>
            <TextBox x:Name="TextBoxKd" TextWrapping="Wrap" Text="Kd:" VerticalAlignment="Top" Width="76" Height="20" Grid.RowSpan="2"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" Margin="168,20,149,28" Grid.Column="1" Grid.Row="1">
            <TextBox x:Name="TextBoxMaxKp" HorizontalAlignment="Left" TextWrapping="Wrap" Text="MaxKp:" VerticalAlignment="Top" Width="70" Height="20"/>
            <TextBox x:Name="TextBoxMaxKi" HorizontalAlignment="Left" TextWrapping="Wrap" Text="MaxKi:" VerticalAlignment="Top" Width="70" Height="20"/>
            <TextBox x:Name="TextBoxMaxKd" TextWrapping="Wrap" Text="MaxKd:" VerticalAlignment="Top" Width="70" Height="20"/>
        </StackPanel>

        <Button x:Name="ButtonPIDx" Content="X" HorizontalAlignment="Left" Margin="418,0,0,0" VerticalAlignment="Top" Width="50" Click="PID_Click" Grid.Column="1" RenderTransformOrigin="0.48,2.277" Grid.Row="1"/>
        <Button x:Name="ButtonPIDthéta" Content="Théta" HorizontalAlignment="Left" Margin="418,23,0,0" Grid.Row="1" Width="50" Click="PID_Click" Grid.Column="1" Height="28" VerticalAlignment="Top"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="10,0,0,42" Width="140" Grid.Column="1" Height="20" VerticalAlignment="Bottom" Grid.Row="1">
            <TextBox x:Name="TextBoxVitLinaire" HorizontalAlignment="Left" TextWrapping="Wrap" Text="VitLin:" VerticalAlignment="Top" Width="70" Height="20" Grid.RowSpan="2"/>
            <TextBox x:Name="TextBoxVitAngulaire" HorizontalAlignment="Left" TextWrapping="Wrap" Text="VitAng:" VerticalAlignment="Top" Width="70" Height="20" Grid.RowSpan="2"/>
        </StackPanel>
        <Button x:Name="ButtonConsigne" Content="Consigne" HorizontalAlignment="Left" Margin="30,45,0,0" VerticalAlignment="Top" Width="120" Click="Consigne_Click" Grid.Column="1" RenderTransformOrigin="0.48,2.277" Grid.Row="1"/>


    </Grid>
</Window>
